# =============================================================================
# LLM-as-Judge Evaluation Pipeline — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your actual API keys.
#   cp .env.example .env
#
# IMPORTANT: Never commit `.env` to version control.
#            `.env` is already listed in .gitignore.
# =============================================================================

# --- API Keys ---
OPENAI_API_KEY=[]
ANTHROPIC_API_KEY=[]

# --- Generator Model (produces outputs to be evaluated) ----------------------
GENERATOR_PROVIDER=openai
GENERATOR_MODEL=gpt-4o

# --- Judge Model (evaluates outputs against the rubric) ----------------------
# Recommended to use a different family from the generator to reduce self-serving bias
JUDGE_PROVIDER=anthropic
JUDGE_MODEL=claude-3-5-sonnet-20241022

# --- Pipeline Configuration --------------------------------------------------
# Number of times to retry a failed API call before giving up
API_RETRY_ATTEMPTS=3

# Delay in seconds between retry attempts
API_RETRY_DELAY_SECONDS=2

# Judge temperature (lower = more deterministic, recommended for evaluation)
JUDGE_TEMPERATURE=0.0

# Generator temperature
GENERATOR_TEMPERATURE=0.7

# --- Paths (relative to project root) ----------------------------------------
TEST_SUITE_PATH=data/test_suite.json
RUBRIC_PATH=data/rubric.json
LOGS_DIR=logs
REPORTS_DIR=reports
